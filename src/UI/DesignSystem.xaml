<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════
         PALETA: 5 cores fixas  Ink #292929 · Gray #585757
                                Cream #F6F6F6 · Orange #FC6A0A · Deep Orange #E74504
         Variações de tom via Opacity apenas.
         ════════════════════════════════════════════════════════ -->

    <!-- BACKGROUNDS / SURFACES -->
    <SolidColorBrush x:Key="Bg"         Color="#292929"/>
    <SolidColorBrush x:Key="Chrome"     Color="#292929"/>
    <SolidColorBrush x:Key="Card"       Color="#F6F6F6"/>
    <SolidColorBrush x:Key="HeaderBg"   Color="#585757" Opacity="0.10"/>
    <SolidColorBrush x:Key="SearchBg"   Color="#585757" Opacity="0.18"/>

    <!-- BORDERS / DIVIDERS -->
    <SolidColorBrush x:Key="Line"       Color="#585757"/>
    <SolidColorBrush x:Key="RowLine"    Color="#585757" Opacity="0.22"/>

    <!-- TEXT — superfície escura (chrome) -->
    <SolidColorBrush x:Key="TextLight"  Color="#F6F6F6"/>
    <SolidColorBrush x:Key="MutedLight" Color="#F6F6F6" Opacity="0.70"/>

    <!-- TEXT — superfície clara (card) -->
    <SolidColorBrush x:Key="Text"       Color="#292929"/>
    <SolidColorBrush x:Key="Muted"      Color="#585757"/>

    <!-- ACCENT / CTA -->
    <SolidColorBrush x:Key="Primary"    Color="#FC6A0A"/>

    <!-- BUTTON STATES -->
    <SolidColorBrush x:Key="Slate"      Color="#585757"/>
    <SolidColorBrush x:Key="SlateHover" Color="#F6F6F6"/>
    <SolidColorBrush x:Key="SlatePress" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="SlateBorder" Color="#585757"/>
    <SolidColorBrush x:Key="Cta"        Color="#FC6A0A"/>
    <SolidColorBrush x:Key="CtaHover"   Color="#E74504"/>
    <SolidColorBrush x:Key="CtaPress"   Color="#E74504"/>
    <SolidColorBrush x:Key="Danger"     Color="#E74504"/>
    <SolidColorBrush x:Key="DangerHover" Color="#C53A03"/>

    <!-- ROW STATES (para superfícies claras) -->
    <SolidColorBrush x:Key="RowHover"   Color="#FC6A0A" Opacity="0.14"/>
    <SolidColorBrush x:Key="RowSelect"  Color="#FC6A0A" Opacity="0.26"/>

    <!-- STATUS (feedback de mensagens) — alinhado à marca. Warning/Error/Info
         reusam a paleta; Success é a única exceção funcional (verde sóbrio),
         assim como Danger já é exceção para "perigo". Sem outras cores externas. -->
    <SolidColorBrush x:Key="StatusInfo"    Color="#585757"/>
    <SolidColorBrush x:Key="StatusSuccess" Color="#4E8A57"/>
    <SolidColorBrush x:Key="StatusWarning" Color="#FC6A0A"/>
    <SolidColorBrush x:Key="StatusError"   Color="#E74504"/>

    <!-- ════════════════════════════════════════════════════════
         BOTÕES
         ════════════════════════════════════════════════════════ -->

    <!-- BtnSecondary: fundo cinza → cream no hover -->
    <Style x:Key="BtnSecondary" TargetType="Button">
        <Setter Property="Background"          Value="{StaticResource Slate}"/>
        <Setter Property="Foreground"          Value="{StaticResource TextLight}"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Padding"             Value="12,9"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="FontWeight"          Value="SemiBold"/>
        <Setter Property="FontFamily"          Value="Segoe UI"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SlateHover}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SlatePress}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- BtnCta: laranja → deep orange no hover -->
    <Style x:Key="BtnCta" TargetType="Button">
        <Setter Property="Background"          Value="{StaticResource Cta}"/>
        <Setter Property="Foreground"          Value="#292929"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Padding"             Value="12,9"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="FontWeight"          Value="Bold"/>
        <Setter Property="FontFamily"          Value="Segoe UI"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource CtaHover}"/>
                            <Setter Property="Foreground" Value="#F6F6F6"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource CtaPress}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- BtnDanger: deep orange para ações destrutivas -->
    <Style x:Key="BtnDanger" TargetType="Button">
        <Setter Property="Background"          Value="{StaticResource Danger}"/>
        <Setter Property="Foreground"          Value="#F6F6F6"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Padding"             Value="12,9"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="FontWeight"          Value="SemiBold"/>
        <Setter Property="FontFamily"          Value="Segoe UI"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         INPUTS
         ════════════════════════════════════════════════════════ -->

    <!-- FieldBox: campo de texto padrão sobre superfície escura -->
    <Style x:Key="FieldBox" TargetType="TextBox">
        <Setter Property="Background"      Value="{StaticResource SearchBg}"/>
        <Setter Property="Foreground"      Value="{StaticResource TextLight}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Line}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Height"          Value="34"/>
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="CaretBrush"      Value="{StaticResource Primary}"/>
        <Setter Property="SelectionBrush"  Value="{StaticResource Primary}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Grid Margin="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Tag}"
                                       Foreground="{StaticResource MutedLight}"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Primary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox padrão sobre superfície clara (Card) -->
    <Style x:Key="CardComboBox" TargetType="ComboBox">
        <Setter Property="Background"      Value="{StaticResource Card}"/>
        <Setter Property="Foreground"      Value="{StaticResource Text}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Line}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Height"          Value="34"/>
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource Text}"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource RowHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource RowSelect}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         DATAGRID
         ════════════════════════════════════════════════════════ -->

    <Style x:Key="DarkDataGridHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background"      Value="{StaticResource HeaderBg}"/>
        <Setter Property="Foreground"      Value="{StaticResource Muted}"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="BorderBrush"     Value="{StaticResource RowLine}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style x:Key="DarkDataGridRow" TargetType="DataGridRow">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource Text}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource RowLine}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource RowHover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource RowSelect}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DarkDataGridCell" TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="{StaticResource Text}"/>
        <Setter Property="Padding"         Value="6,4"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background"  Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         CHECKBOX (ChkCell)
         ════════════════════════════════════════════════════════ -->

    <Style x:Key="ChkCell" TargetType="CheckBox">
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="18" Height="18">
                        <Border x:Name="Bg"
                                Background="{StaticResource Card}"
                                BorderBrush="{StaticResource SlateBorder}"
                                BorderThickness="1.5"
                                CornerRadius="4"
                                SnapsToDevicePixels="True"/>
                        <Path x:Name="Check"
                              Data="M3,9 L7,13 L15,5"
                              Stroke="#292929" StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Visibility="Collapsed"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bg"    Property="Background"  Value="{StaticResource Primary}"/>
                            <Setter TargetName="Bg"    Property="BorderBrush" Value="{StaticResource Primary}"/>
                            <Setter TargetName="Check" Property="Visibility"  Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Primary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         PROGRESSBAR (ProgressDark)
         ════════════════════════════════════════════════════════ -->

    <Style x:Key="ProgressDark" TargetType="ProgressBar">
        <Setter Property="Height"     Value="6"/>
        <Setter Property="Foreground" Value="{StaticResource Primary}"/>
        <Setter Property="Background" Value="{StaticResource SearchBg}"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         CAMPO DE BUSCA (SearchBox + ClearBtn) — input com lupa
         e placeholder. Consolidado do antigo Theme.xaml.
         ════════════════════════════════════════════════════════ -->

    <Style x:Key="SearchBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Primary}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource Primary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd" CornerRadius="6"
                            Background="{StaticResource SearchBg}"
                            BorderBrush="{StaticResource Line}" BorderThickness="1.5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Margin="11,0,8,0" VerticalAlignment="Center"
                                  Stroke="{StaticResource MutedLight}" StrokeThickness="1.6"
                                  Data="M7,7 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0 M11,11 L15,15"/>
                            <TextBlock x:Name="ph" Grid.Column="1" Text="Buscar..."
                                       Foreground="{StaticResource MutedLight}"
                                       VerticalAlignment="Center" Margin="2,0,34,0"
                                       Visibility="Collapsed" IsHitTestVisible="False"/>
                            <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1"
                                          Margin="0,0,34,0" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="ph" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Primary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ClearBtn" TargetType="Button">
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="ToolTip" Value="Limpar busca"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="cb" CornerRadius="11" Background="Transparent">
                        <Path x:Name="xp" HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M6,6 L14,14 M14,6 L6,14"
                              Stroke="{StaticResource MutedLight}" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="cb" Property="Background" Value="{StaticResource SearchBg}"/>
                            <Setter TargetName="xp" Property="Stroke" Value="{StaticResource TextLight}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         LISTVIEW / GRIDVIEW (estilos default) — usados pelas
         janelas de lista (Image Capture, Model Cleanup).
         Consolidado do antigo Theme.xaml.
         ════════════════════════════════════════════════════════ -->

    <Style TargetType="GridViewColumnHeader">
        <Setter Property="Foreground" Value="{StaticResource Muted}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <Border Background="{StaticResource HeaderBg}"
                            BorderBrush="{StaticResource RowLine}"
                            BorderThickness="0,0,1,1" Padding="10,8">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListViewItem">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource RowLine}" BorderThickness="0,0,0,1"
                            Padding="2,7">
                        <GridViewRowPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RowHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RowSelect}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
