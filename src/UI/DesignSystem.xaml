<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════
         PALETA (tema claro corporativo)
           Fundo principal #E5E7EB · Painel lateral #E0E2E6
           Cards #F3F4F6 · Cabeçalho tabela #D6D9DE · Busca #F8F9FA
           Bordas #C5C9D0 · Hover linha #DCEAFE · Seleção #BFDBFE
           Texto #1F2937 · Secundário #4B5563 · Desabilitado #9CA3AF
           Primário #2563EB · Hover #1D4ED8
           Sucesso #15803D · Aviso #D97706 · Erro #DC2626
         NOTA: os tokens *Light (TextLight/MutedLight) historicamente eram
         "texto sobre chrome escuro". No tema claro o chrome passou a ser
         claro, então estes tokens agora resolvem para texto ESCURO — os
         nomes foram mantidos para preservar as referências das janelas.
         ════════════════════════════════════════════════════════ -->

    <!-- BACKGROUNDS / SURFACES -->
    <SolidColorBrush x:Key="Bg"         Color="#E5E7EB"/>  <!-- Fundo principal     -->
    <SolidColorBrush x:Key="Chrome"     Color="#E0E2E6"/>  <!-- Painel lateral/topo -->
    <SolidColorBrush x:Key="Card"       Color="#F3F4F6"/>  <!-- Cards / containers   -->
    <SolidColorBrush x:Key="HeaderBg"   Color="#D6D9DE"/>  <!-- Cabeçalho de tabela  -->
    <SolidColorBrush x:Key="SearchBg"   Color="#F8F9FA"/>  <!-- Campo de busca       -->
    <SolidColorBrush x:Key="RowAlt"     Color="#ECEEF1"/>  <!-- Linha alternada (zebra) -->

    <!-- BORDERS / DIVIDERS -->
    <SolidColorBrush x:Key="Line"       Color="#C5C9D0"/>
    <SolidColorBrush x:Key="RowLine"    Color="#C5C9D0" Opacity="0.6"/>

    <!-- TEXT — superfície de topo/chrome (agora CLARA → texto escuro) -->
    <SolidColorBrush x:Key="TextLight"  Color="#1F2937"/>
    <SolidColorBrush x:Key="MutedLight" Color="#4B5563"/>

    <!-- TEXT — superfície clara (card) -->
    <SolidColorBrush x:Key="Text"         Color="#1F2937"/>  <!-- Texto principal    -->
    <SolidColorBrush x:Key="Muted"        Color="#4B5563"/>  <!-- Texto secundário   -->
    <SolidColorBrush x:Key="TextDisabled" Color="#9CA3AF"/>  <!-- Texto desabilitado -->

    <!-- TEXT — sobre superfícies coloridas fortes (botão primário/erro) -->
    <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFF"/>

    <!-- ACCENT / CTA -->
    <SolidColorBrush x:Key="Primary"    Color="#2563EB"/>

    <!-- BUTTON STATES -->
    <SolidColorBrush x:Key="Slate"       Color="#E5E7EB"/>  <!-- Botão secundário        -->
    <SolidColorBrush x:Key="SlateHover"  Color="#D1D5DB"/>  <!-- Hover secundário        -->
    <SolidColorBrush x:Key="SlatePress"  Color="#C5C9D0"/>  <!-- Pressionado secundário  -->
    <SolidColorBrush x:Key="SlateBorder" Color="#C5C9D0"/>
    <SolidColorBrush x:Key="Cta"         Color="#2563EB"/>  <!-- Botão primário          -->
    <SolidColorBrush x:Key="CtaHover"    Color="#1D4ED8"/>  <!-- Hover primário          -->
    <SolidColorBrush x:Key="CtaPress"    Color="#1E40AF"/>  <!-- Pressionado primário    -->
    <SolidColorBrush x:Key="Danger"      Color="#DC2626"/>
    <SolidColorBrush x:Key="DangerHover" Color="#B91C1C"/>

    <!-- ROW STATES (para superfícies claras) -->
    <SolidColorBrush x:Key="RowHover"   Color="#DCEAFE"/>  <!-- Azul suave         -->
    <SolidColorBrush x:Key="RowSelect"  Color="#BFDBFE"/>  <!-- Azul corporativo   -->

    <!-- STATUS (feedback de mensagens, alertas e notificações) -->
    <SolidColorBrush x:Key="StatusInfo"    Color="#2563EB"/>
    <SolidColorBrush x:Key="StatusSuccess" Color="#15803D"/>
    <SolidColorBrush x:Key="StatusWarning" Color="#D97706"/>
    <SolidColorBrush x:Key="StatusError"   Color="#DC2626"/>

    <!-- ════════════════════════════════════════════════════════
         BOTÕES
         ════════════════════════════════════════════════════════ -->

    <!-- BtnSecondary: cinza neutro → cinza mais escuro no hover (texto sempre escuro) -->
    <Style x:Key="BtnSecondary" TargetType="Button">
        <Setter Property="Background"          Value="{StaticResource Slate}"/>
        <Setter Property="Foreground"          Value="{StaticResource Text}"/>
        <Setter Property="BorderBrush"         Value="{StaticResource SlateBorder}"/>
        <Setter Property="BorderThickness"     Value="0.8"/>
        <Setter Property="Padding"             Value="12,9"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="FontWeight"          Value="SemiBold"/>
        <Setter Property="FontFamily"          Value="Segoe UI"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SlateHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SlatePress}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            <Setter Property="Foreground" Value="{StaticResource TextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- BtnCta: azul institucional → azul escuro no hover (texto branco) -->
    <Style x:Key="BtnCta" TargetType="Button">
        <Setter Property="Background"          Value="{StaticResource Cta}"/>
        <Setter Property="Foreground"          Value="{StaticResource TextOnAccent}"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Padding"             Value="12,9"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="FontWeight"          Value="Bold"/>
        <Setter Property="FontFamily"          Value="Segoe UI"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource CtaHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource CtaPress}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- BtnDanger: vermelho para ações destrutivas (texto branco) -->
    <Style x:Key="BtnDanger" TargetType="Button">
        <Setter Property="Background"          Value="{StaticResource Danger}"/>
        <Setter Property="Foreground"          Value="{StaticResource TextOnAccent}"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Padding"             Value="12,9"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="FontWeight"          Value="SemiBold"/>
        <Setter Property="FontFamily"          Value="Segoe UI"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         INPUTS
         ════════════════════════════════════════════════════════ -->

    <!-- FieldBox: campo de texto padrão (superfície clara de busca) -->
    <Style x:Key="FieldBox" TargetType="TextBox">
        <Setter Property="Background"      Value="{StaticResource SearchBg}"/>
        <Setter Property="Foreground"      Value="{StaticResource Text}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Line}"/>
        <Setter Property="BorderThickness" Value="0.8"/>
        <Setter Property="Height"          Value="34"/>
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="CaretBrush"      Value="{StaticResource Primary}"/>
        <Setter Property="SelectionBrush"  Value="{StaticResource Primary}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Grid Margin="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Tag}"
                                       Foreground="{StaticResource TextDisabled}"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Primary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox padrão sobre superfície clara (Card) -->
    <Style x:Key="CardComboBox" TargetType="ComboBox">
        <Setter Property="Background"      Value="{StaticResource Card}"/>
        <Setter Property="Foreground"      Value="{StaticResource Text}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Line}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Height"          Value="34"/>
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource Text}"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource RowHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource RowSelect}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         DATAGRID
         ════════════════════════════════════════════════════════ -->

    <Style x:Key="DarkDataGridHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background"      Value="{StaticResource HeaderBg}"/>
        <Setter Property="Foreground"      Value="{StaticResource Text}"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Line}"/>
        <Setter Property="BorderThickness" Value="0,0,0.8,0.8"/>
    </Style>

    <Style x:Key="DarkDataGridRow" TargetType="DataGridRow">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource Text}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource RowLine}"/>
        <Setter Property="BorderThickness" Value="0,0,0,0.8"/>
        <Style.Triggers>
            <Trigger Property="AlternationIndex" Value="1">
                <Setter Property="Background" Value="{StaticResource RowAlt}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource RowHover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource RowSelect}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DarkDataGridCell" TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="{StaticResource Text}"/>
        <Setter Property="Padding"         Value="6,4"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background"  Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         CHECKBOX (ChkCell)
         ════════════════════════════════════════════════════════ -->

    <Style x:Key="ChkCell" TargetType="CheckBox">
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="18" Height="18">
                        <Border x:Name="Bg"
                                Background="{StaticResource SearchBg}"
                                BorderBrush="{StaticResource SlateBorder}"
                                BorderThickness="0.8"
                                CornerRadius="4"
                                SnapsToDevicePixels="True"/>
                        <Path x:Name="Check"
                              Data="M3,9 L7,13 L15,5"
                              Stroke="{StaticResource TextOnAccent}" StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Visibility="Collapsed"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bg"    Property="Background"  Value="{StaticResource Primary}"/>
                            <Setter TargetName="Bg"    Property="BorderBrush" Value="{StaticResource Primary}"/>
                            <Setter TargetName="Check" Property="Visibility"  Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Primary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         PROGRESSBAR (ProgressDark)
         ════════════════════════════════════════════════════════ -->

    <Style x:Key="ProgressDark" TargetType="ProgressBar">
        <Setter Property="Height"     Value="6"/>
        <Setter Property="Foreground" Value="{StaticResource Primary}"/>
        <Setter Property="Background" Value="{StaticResource Line}"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         CAMPO DE BUSCA (SearchBox + ClearBtn) — input com lupa
         e placeholder. Consolidado do antigo Theme.xaml.
         ════════════════════════════════════════════════════════ -->

    <Style x:Key="SearchBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Primary}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource Primary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd" CornerRadius="6"
                            Background="{StaticResource SearchBg}"
                            BorderBrush="{StaticResource Line}" BorderThickness="0.8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Margin="11,0,8,0" VerticalAlignment="Center"
                                  Stroke="{StaticResource Muted}" StrokeThickness="1.6"
                                  Data="M7,7 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0 M11,11 L15,15"/>
                            <TextBlock x:Name="ph" Grid.Column="1" Text="Buscar..."
                                       Foreground="{StaticResource TextDisabled}"
                                       VerticalAlignment="Center" Margin="2,0,34,0"
                                       Visibility="Collapsed" IsHitTestVisible="False"/>
                            <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1"
                                          Margin="0,0,34,0" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="ph" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Primary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ClearBtn" TargetType="Button">
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="ToolTip" Value="Limpar busca"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="cb" CornerRadius="11" Background="Transparent">
                        <Path x:Name="xp" HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="M6,6 L14,14 M14,6 L6,14"
                              Stroke="{StaticResource Muted}" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="cb" Property="Background" Value="{StaticResource SlateHover}"/>
                            <Setter TargetName="xp" Property="Stroke" Value="{StaticResource Text}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════
         LISTVIEW / GRIDVIEW (estilos default) — usados pelas
         janelas de lista (Image Capture, Model Cleanup).
         Consolidado do antigo Theme.xaml.
         ════════════════════════════════════════════════════════ -->

    <Style TargetType="GridViewColumnHeader">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <Border Background="{StaticResource HeaderBg}"
                            BorderBrush="{StaticResource Line}"
                            BorderThickness="0,0,0.8,0.8" Padding="10,8">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListViewItem">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource RowLine}" BorderThickness="0,0,0,0.8"
                            Padding="2,7">
                        <GridViewRowPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RowAlt}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RowHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource RowSelect}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
