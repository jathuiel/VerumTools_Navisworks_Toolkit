<Window x:Class="NavisworksToolkit.Modules.AttributeLab.NativeAttrLabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NavisworksToolkit.Modules.AttributeLab"
        Title="Property Explorer"
        Width="1080" Height="760"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#E5E7EB"
        FontFamily="Segoe UI, San Francisco PRO, Helvetica Neue"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NavisworksToolkit;component/UI/DesignSystem.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="{StaticResource Chrome}"
                BorderBrush="{StaticResource Line}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- barra de acento  -->
                    <ColumnDefinition Width="*"/>      <!-- títulos          -->
                    <ColumnDefinition Width="Auto"/>  <!-- logo (canto dir.) -->
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="4" CornerRadius="2"
                        Background="{StaticResource Primary}" Margin="0,2,14,2"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Property Explorer"
                               Foreground="{StaticResource TextLight}"
                               FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,3"/>
                    <TextBlock Text="Escreva atributos por seleção, inclua nomes de sets e valide o resultado."
                               Foreground="{StaticResource MutedLight}"
                               FontSize="12"/>
                </StackPanel>
                <Image Grid.Column="2" x:Name="PartnersLogo" Height="86" Stretch="Uniform"
                       VerticalAlignment="Center" Margin="16,0,0,0"
                       RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True"/>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" MinWidth="300"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PAINEL ESQUERDO — Atributos Nativos -->
            <Border Grid.Column="0"
                    Background="{StaticResource Card}"
                    BorderBrush="{StaticResource Line}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource HeaderBg}"
                            BorderBrush="{StaticResource RowLine}"
                            BorderThickness="0,0,0,1"
                            Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="ATRIBUTOS NATIVOS"
                                       Foreground="{StaticResource Text}"
                                       FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock x:Name="NativeSubtitle" Text="(carregando...)"
                                       Foreground="{StaticResource Muted}"
                                       FontSize="10" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <TreeView x:Name="NativeTree" Grid.Row="1"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="6"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="False"/>
                                <Setter Property="Padding" Value="2"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type local:LabCatNode}" ItemsSource="{Binding Properties}">
                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                    <Border Background="{StaticResource Primary}"
                                            CornerRadius="2" Padding="4,1" Margin="0,0,6,0">
                                        <TextBlock Text="CAT"
                                                   Foreground="{StaticResource TextOnAccent}"
                                                   FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Text}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                            <DataTemplate DataType="{x:Type local:LabPropNode}">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{StaticResource Text}"
                                               FontSize="11" VerticalAlignment="Center" MinWidth="100"/>
                                    <TextBlock Text=" = "
                                               Foreground="{StaticResource Muted}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding Value}"
                                               Foreground="{StaticResource Primary}"
                                               FontSize="11" VerticalAlignment="Center"
                                               MaxWidth="140" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Value}"/>
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>

                    <Button x:Name="BtnReloadNative" Grid.Row="2"
                            Content="Recarregar Seleção"
                            Style="{StaticResource BtnSecondary}"
                            Margin="10,6,10,10"
                            HorizontalAlignment="Stretch"
                            Click="BtnReloadNative_Click"/>
                </Grid>
            </Border>

            <!-- DIVISOR -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource Line}"/>

            <!-- PAINEL DIREITO -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <Grid Margin="18,14,18,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <!-- PASSO 1 — Importar categoria nativa -->
                    <Border Grid.Row="0"
                            Background="{StaticResource Card}"
                            BorderBrush="{StaticResource Line}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                       FontSize="11" FontWeight="SemiBold"
                                       Margin="0,0,0,8">
                                <Run Text="1 — " Foreground="{StaticResource Primary}"/>
                                <Run Text="IMPORTAR PROPRIEDADES DE UMA CATEGORIA NATIVA" Foreground="{StaticResource Text}"/>
                            </TextBlock>

                            <ComboBox x:Name="NativeCategoryCombo"
                                      Grid.Row="1" Grid.Column="0"
                                      Style="{StaticResource CardComboBox}"
                                      Margin="0,0,8,0"/>

                            <Button x:Name="BtnImportNative"
                                    Grid.Row="1" Grid.Column="1"
                                    Content="Importar"
                                    Style="{StaticResource BtnCta}"
                                    Click="BtnImportNative_Click"/>
                        </Grid>
                    </Border>

                    <!-- PASSO 2 — Nome da categoria custom -->
                    <Border Grid.Row="1"
                            Background="{StaticResource Card}"
                            BorderBrush="{StaticResource Line}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       FontSize="11" FontWeight="SemiBold"
                                       Margin="0,0,0,8">
                                <Run Text="2 — " Foreground="{StaticResource Primary}"/>
                                <Run Text="NOME DA CATEGORIA CUSTOM" Foreground="{StaticResource Text}"/>
                            </TextBlock>

                            <TextBox x:Name="CustomCategoryNameBox"
                                     Grid.Row="1"
                                     Style="{StaticResource FieldBox}"
                                     Background="{StaticResource SearchBg}"
                                     GotFocus="EditingTextBox_GotFocus"/>

                            <TextBlock Grid.Row="2"
                                       Margin="0,6,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource Muted}"
                                       TextWrapping="Wrap"
                                       Text="Use o nome padrão para gravação normal ou reutilize um nome nativo para comparar comportamento."/>
                        </Grid>
                    </Border>

                    <!-- PASSO 3 — Selection Sets -->
                    <Border Grid.Row="2"
                            Background="{StaticResource Card}"
                            BorderBrush="{StaticResource Line}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,12"
                            Margin="0,0,0,12"
                            MinHeight="240">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       FontSize="11" FontWeight="SemiBold">
                                <Run Text="3 — " Foreground="{StaticResource Primary}"/>
                                <Run Text="SELECTION SETS DETECTADOS" Foreground="{StaticResource Text}"/>
                            </TextBlock>

                            <Grid Grid.Row="1" Margin="0,6,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SetsSummaryText"
                                           Grid.Column="0"
                                           Foreground="{StaticResource Muted}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Text="0 set(s) detectado(s)."/>
                                <Button Grid.Column="1" Content="Selecionar Todos"
                                        Style="{StaticResource BtnSecondary}"
                                        Padding="8,4"
                                        Margin="8,0,0,0"
                                        Click="BtnSelectAllSets_Click"/>
                                <Button Grid.Column="2" Content="Limpar"
                                        Style="{StaticResource BtnSecondary}"
                                        Padding="8,4"
                                        Margin="6,0,0,0"
                                        Click="BtnClearSets_Click"/>
                                <Button Grid.Column="3" Content="Recarregar"
                                        Style="{StaticResource BtnSecondary}"
                                        Padding="8,4"
                                        Margin="6,0,0,0"
                                        Click="BtnReloadSets_Click"/>
                            </Grid>

                            <DataGrid x:Name="SelectionSetsGrid" Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      IsReadOnly="False"
                                      SelectionMode="Single"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      BorderThickness="1"
                                      BorderBrush="{StaticResource Line}"
                                      Background="Transparent"
                                      RowBackground="Transparent"
                                      AlternationCount="2"
                                      ColumnHeaderStyle="{StaticResource DarkDataGridHeader}"
                                      CellStyle="{StaticResource DarkDataGridCell}"
                                      RowStyle="{StaticResource DarkDataGridRow}">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Usar" Width="60"
                                                            Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTextColumn Header="Set" Width="*" IsReadOnly="True"
                                                        Binding="{Binding Name}"/>
                                    <DataGridTextColumn Header="Elementos" Width="110" IsReadOnly="True"
                                                        Binding="{Binding ElementCount}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- PASSO 4 — Atributos extras -->
                    <Grid Grid.Row="3" Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="220"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,8">
                            <Run Text="4 — " Foreground="{StaticResource Primary}"/>
                            <Run Text="ATRIBUTOS EXTRAS A GRAVAR" Foreground="{StaticResource Text}"/>
                        </TextBlock>

                        <Border Grid.Row="1"
                                Background="{StaticResource Card}"
                                BorderBrush="{StaticResource Line}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="1">
                            <DataGrid x:Name="LabGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      IsReadOnly="False" SelectionUnit="CellOrRowHeader"
                                      PreparingCellForEdit="LabGrid_PreparingCellForEdit"
                                      Background="{StaticResource Card}"
                                      BorderThickness="0"
                                      RowBackground="Transparent"
                                      AlternationCount="2"
                                      GridLinesVisibility="None"
                                      HeadersVisibility="Column"
                                      ColumnHeaderHeight="32"
                                      ColumnHeaderStyle="{StaticResource DarkDataGridHeader}"
                                      CellStyle="{StaticResource DarkDataGridCell}"
                                      RowStyle="{StaticResource DarkDataGridRow}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nome do Atributo" Width="*"
                                                        Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTextColumn Header="Valor" Width="*"
                                                        Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTemplateColumn Header="Tipo" Width="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox SelectedValue="{Binding Type, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                          SelectedValuePath="Content"
                                                          Foreground="{StaticResource Text}"
                                                          BorderThickness="1"
                                                          BorderBrush="{StaticResource Line}"
                                                          Background="{StaticResource Card}"
                                                          Padding="6,3"
                                                          FontSize="12"
                                                          Height="28">
                                                    <ComboBoxItem>string</ComboBoxItem>
                                                    <ComboBoxItem>int</ComboBoxItem>
                                                    <ComboBoxItem>double</ComboBoxItem>
                                                    <ComboBoxItem>boolean</ComboBoxItem>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="" Width="34">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="×"
                                                        Style="{StaticResource BtnDanger}"
                                                        Width="24" Height="20"
                                                        FontSize="11" Padding="0"
                                                        Tag="{Binding}"
                                                        Click="BtnRemoveLabRow_Click"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Button x:Name="BtnAddLabRow" Grid.Row="2"
                                Content="+ Adicionar Linha"
                                Style="{StaticResource BtnSecondary}"
                                Padding="10,6"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Click="BtnAddLabRow_Click"/>
                    </Grid>

                    <!-- BARRA DE AÇÕES -->
                    <Grid Grid.Row="4" Margin="0,8,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnImportAttributes" Grid.Column="0"
                                Content="Importar CSV/XML"
                                Style="{StaticResource BtnSecondary}"
                                Margin="0,0,8,0"
                                Click="BtnImportAttributes_Click"/>

                        <Button x:Name="BtnExportAttributes" Grid.Column="1"
                                Content="Exportar CSV/XML"
                                Style="{StaticResource BtnSecondary}"
                                Margin="0,0,8,0"
                                Click="BtnExportAttributes_Click"/>

                        <Button x:Name="BtnDeleteCategory" Grid.Column="2"
                                Content="Excluir Categoria"
                                Style="{StaticResource BtnDanger}"
                                Margin="0,0,8,0"
                                Click="BtnDeleteCategory_Click"/>

                        <Button x:Name="BtnWriteAndVerify" Grid.Column="3"
                                Content="5 — Escrever e Verificar Resultado"
                                Style="{StaticResource BtnCta}"
                                HorizontalAlignment="Stretch"
                                Click="BtnWriteAndVerify_Click"/>
                    </Grid>

                    <!-- PASSO 6 — Log de Verificação -->
                    <Border Grid.Row="5"
                            Background="{StaticResource Card}"
                            BorderBrush="{StaticResource Line}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{StaticResource HeaderBg}"
                                    BorderBrush="{StaticResource RowLine}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <Run Text="6 — " Foreground="{StaticResource Primary}"/>
                                        <Run Text="LOG DE VERIFICAÇÃO" Foreground="{StaticResource Text}"/>
                                    </TextBlock>
                                    <Button x:Name="BtnClearLog"
                                            Content="Limpar"
                                            Style="{StaticResource BtnSecondary}"
                                            Padding="6,3"
                                            Margin="12,0,0,0"
                                            FontSize="11"
                                            Click="BtnClearLog_Click"/>
                                </StackPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="12,10">
                                <TextBlock x:Name="LogText"
                                           Foreground="{StaticResource Text}"
                                           FontFamily="Cascadia Mono, Consolas"
                                           FontSize="11"
                                           LineHeight="16"
                                           TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2"
                Background="{StaticResource Chrome}"
                BorderBrush="{StaticResource Line}"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <DockPanel LastChildFill="False">
                <Ellipse DockPanel.Dock="Left" Width="8" Height="8"
                         Fill="{StaticResource Primary}"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"/>
                <TextBlock DockPanel.Dock="Left" x:Name="FooterStatus"
                           Foreground="{StaticResource MutedLight}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Text="Aguardando seleção no modelo..."/>
                <TextBlock DockPanel.Dock="Right" x:Name="VersionText" Text=""
                           Foreground="{StaticResource MutedLight}"
                           FontSize="11" Opacity="0.85"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
