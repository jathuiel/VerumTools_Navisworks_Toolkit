<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="NavisworksToolkit.Modules.ImageExporter.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Capture"
        Height="700" Width="920" MinHeight="540" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Background="#E5E7EB"
        FontFamily="Segoe UI, San Francisco PRO, Helvetica Neue"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NavisworksToolkit;component/UI/DesignSystem.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Rótulo de campo (sobre o chrome claro) -->
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource MutedLight}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>

            <!-- Campo de texto simples (resolução, qualidade, prefixo/sufixo, pasta) -->
            <Style x:Key="FieldBox" TargetType="TextBox">
                <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
                <Setter Property="CaretBrush" Value="{StaticResource Primary}"/>
                <Setter Property="SelectionBrush" Value="{StaticResource Primary}"/>
                <Setter Property="Background" Value="{StaticResource SearchBg}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Height" Value="34"/>
                <Setter Property="Padding" Value="9,0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="bd" CornerRadius="6"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Checkbox com rótulo (opção "incluir markups") -->
            <Style x:Key="CheckOption" TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <StackPanel Orientation="Horizontal" Background="Transparent">
                                <Border x:Name="box" Width="18" Height="18" CornerRadius="4"
                                        Background="{StaticResource SearchBg}"
                                        BorderBrush="{StaticResource SlateBorder}" BorderThickness="1.5"
                                        VerticalAlignment="Center">
                                    <Path x:Name="check" Visibility="Collapsed" Data="M4,9 L8,13 L14,5"
                                          Stroke="{StaticResource TextOnAccent}" StrokeThickness="2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center" Margin="8,0,0,0"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="box" Property="Background" Value="{StaticResource Primary}"/>
                                    <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                    <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===================== Header ===================== -->
        <Border Grid.Row="0" Background="{StaticResource Chrome}" Padding="20,14"
                BorderThickness="0,0,0,1" BorderBrush="{StaticResource Line}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="4" CornerRadius="2"
                        Background="{StaticResource Primary}" Margin="0,2,14,2"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Image Capture" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextLight}"/>
                    <TextBlock Text="Exporte imagens JPG dos Viewpoints selecionados"
                               FontSize="12" Foreground="{StaticResource MutedLight}" Margin="0,3,0,0"/>
                </StackPanel>
                <Image Grid.Column="2" x:Name="PartnersLogo" Height="86" Stretch="Uniform"
                       VerticalAlignment="Center" Margin="16,0,0,0"
                       RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True"/>
            </Grid>
        </Border>

        <!-- ===================== Conteúdo ===================== -->
        <Grid Grid.Row="1" Margin="20,16,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Lista de viewpoints -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="VIEWPOINTS" FontWeight="SemiBold" FontSize="11"
                           Foreground="{StaticResource MutedLight}" Margin="2,0,0,8"/>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <TextBox x:Name="VpsSearch" Style="{StaticResource SearchBox}"
                             TextChanged="VpsSearch_TextChanged"/>
                    <Button x:Name="VpsClearSearch" Style="{StaticResource ClearBtn}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,8,0" Visibility="Collapsed" Click="VpsClearSearch_Click"/>
                </Grid>

                <Border Grid.Row="2" CornerRadius="8" Background="{StaticResource Card}"
                        BorderBrush="{StaticResource Line}" BorderThickness="1">
                    <ListView x:Name="VpsList" Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource Text}" AlternationCount="2"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="40">
                                    <GridViewColumn.Header>
                                        <CheckBox x:Name="VpsSelectAll" Style="{StaticResource ChkCell}"
                                                  IsThreeState="True" ToolTip="Selecionar todos"
                                                  Click="VpsSelectAll_Click"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource ChkCell}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="NOME" Width="430">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource Text}"
                                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <Border Margin="6,0,0,0" CornerRadius="3" Padding="4,0"
                                                            Background="{StaticResource Primary}" VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDuplicate}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="duplicado" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextOnAccent}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Path}" Foreground="{StaticResource Muted}"
                                                           FontSize="10" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <TextBlock Grid.Row="3" x:Name="VpsCountLabel" Text="0 viewpoint(s)"
                           Foreground="{StaticResource MutedLight}" FontSize="11"
                           FontFamily="Cascadia Mono, Consolas" Margin="2,8,0,0"/>
            </Grid>

            <!-- Painel de opções (rolável p/ caber em janelas baixas) -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="OPÇÕES DE EXPORTAÇÃO" FontWeight="SemiBold" FontSize="11"
                           Foreground="{StaticResource MutedLight}" Margin="0,0,0,12"/>

                <TextBlock Text="Pasta de destino" Style="{StaticResource FieldLabel}"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="OutputFolderBox" Style="{StaticResource FieldBox}"/>
                    <Button Grid.Column="1" x:Name="BrowseButton" Content="..."
                            Style="{StaticResource BtnSecondary}" Margin="6,0,0,0"
                            Padding="12,0" Click="BrowseButton_Click"/>
                </Grid>

                <TextBlock Text="Resolução (px)" Style="{StaticResource FieldLabel}"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="WidthBox" Style="{StaticResource FieldBox}" Text="1920"/>
                    <TextBlock Grid.Column="1" Text="×" Foreground="{StaticResource MutedLight}"
                               VerticalAlignment="Center" Margin="8,0"/>
                    <TextBox Grid.Column="2" x:Name="HeightBox" Style="{StaticResource FieldBox}" Text="1080"/>
                </Grid>

                <TextBlock Text="Qualidade JPEG (0–100)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="QualityBox" Style="{StaticResource FieldBox}" Text="90" Margin="0,0,0,12"/>

                <TextBlock Text="Prefixo do nome" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="PrefixBox" Style="{StaticResource FieldBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Sufixo do nome" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="SuffixBox" Style="{StaticResource FieldBox}" Margin="0,0,0,14"/>

                <CheckBox x:Name="MarkupsCheck" Style="{StaticResource CheckOption}"
                          Content="Incluir markups (overlays)" IsChecked="True" Margin="0,0,0,14"/>

                <Border Height="1" Background="{StaticResource Line}" Margin="0,0,0,12"/>
                <TextBlock x:Name="SelInfoLabel" Text="0 selecionado(s)"
                           Foreground="{StaticResource TextLight}" FontFamily="Cascadia Mono, Consolas"
                           FontSize="12"/>
            </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ===================== Ações ===================== -->
        <Border Grid.Row="2" Padding="20,14,20,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="RefreshButton" Content="Atualizar"
                        Style="{StaticResource BtnSecondary}" Margin="0,0,8,0"
                        Click="RefreshButton_Click"/>
                <Button x:Name="ExportButton" Content="Exportar selecionados"
                        Style="{StaticResource BtnCta}" Click="ExportButton_Click"/>
            </StackPanel>
        </Border>

        <!-- ===================== Footer ===================== -->
        <Border Grid.Row="3" Background="{StaticResource Chrome}" Padding="20,12"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource Line}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{StaticResource Primary}"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1" x:Name="StatusLabel" Text="Pronto"
                               Foreground="{StaticResource MutedLight}" FontSize="12"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="2" x:Name="ProgressLabel" Text=""
                               Foreground="{StaticResource Primary}" FontSize="12"
                               FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock Grid.Column="3" x:Name="VersionText" Text=""
                               Foreground="{StaticResource MutedLight}" FontSize="11" Opacity="0.85"
                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                </Grid>
                <ProgressBar Grid.Row="1" x:Name="OperationProgress"
                             Style="{StaticResource ProgressDark}"
                             Height="6" Margin="0,10,0,2"
                             Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Window>
