<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="NavisworksToolkit.Modules.ModelCleaner.CleanupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Model Cleanup"
        Height="900" Width="900" MinHeight="520" MinWidth="780"
        WindowStartupLocation="CenterScreen"
        Background="#E5E7EB"
        FontFamily="Segoe UI, San Francisco PRO, Helvetica Neue"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/NavisworksToolkit;component/UI/DesignSystem.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header  -->
            <RowDefinition Height="*"/>      <!-- listas  -->
            <RowDefinition Height="Auto"/>  <!-- ações   -->
            <RowDefinition Height="Auto"/>  <!-- footer  -->
        </Grid.RowDefinitions>

        <!-- ===================== Header ===================== -->
        <Border Grid.Row="0" Background="{StaticResource Chrome}" Padding="20,14"
                BorderThickness="0,0,0,0.8" BorderBrush="{StaticResource Line}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="4" CornerRadius="2"
                        Background="{StaticResource Primary}" Margin="0,2,14,2"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Model Cleanup" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextLight}"/>
                    <TextBlock Text="Remova Search Sets e Viewpoints indesejados do modelo"
                               FontSize="12" Foreground="{StaticResource MutedLight}" Margin="0,3,0,0"/>
                </StackPanel>
                <Image Grid.Column="2" x:Name="PartnersLogo" Height="86" Stretch="Uniform"
                       VerticalAlignment="Center" Margin="16,0,0,0"
                       RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True"/>
            </Grid>
        </Border>

        <!-- ===================== Conteúdo: duas listas lado a lado ===================== -->
        <Grid Grid.Row="1" Margin="20,16,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Coluna: Search/Selection Sets -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="SEARCH SETS / CONJUNTOS" FontWeight="SemiBold"
                           FontSize="11" Foreground="{StaticResource MutedLight}" Margin="2,0,0,8"/>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <TextBox x:Name="SetsSearch" Style="{StaticResource SearchBox}"
                             TextChanged="SetsSearch_TextChanged"/>
                    <Button x:Name="SetsClearSearch" Style="{StaticResource ClearBtn}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,8,0" Visibility="Collapsed" Click="SetsClearSearch_Click"/>
                </Grid>

                <Border Grid.Row="2" CornerRadius="8" Background="{StaticResource Card}"
                        BorderBrush="{StaticResource Line}" BorderThickness="0.8">
                    <ListView x:Name="SetsList" Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource Text}" AlternationCount="2"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="40">
                                    <GridViewColumn.Header>
                                        <CheckBox x:Name="SetsSelectAll" Style="{StaticResource ChkCell}"
                                                  IsThreeState="True" ToolTip="Selecionar todos"
                                                  Click="SetsSelectAll_Click"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource ChkCell}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="TIPO" Width="66">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TypeLabel}" Foreground="{StaticResource Muted}"
                                                       Padding="8,0,0,0"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="NOME" Width="230">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource Text}"
                                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Path}" Foreground="{StaticResource Muted}"
                                                           FontSize="10" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <TextBlock Grid.Row="3" x:Name="SetsCountLabel" Text="0 conjunto(s)"
                           Foreground="{StaticResource MutedLight}" FontSize="11"
                           FontFamily="Cascadia Mono, Consolas" Margin="2,8,0,0"/>
            </Grid>

            <!-- Coluna: Viewpoints -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="VIEWPOINTS" FontWeight="SemiBold"
                           FontSize="11" Foreground="{StaticResource MutedLight}" Margin="2,0,0,8"/>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <TextBox x:Name="VpsSearch" Style="{StaticResource SearchBox}"
                             TextChanged="VpsSearch_TextChanged"/>
                    <Button x:Name="VpsClearSearch" Style="{StaticResource ClearBtn}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,8,0" Visibility="Collapsed" Click="VpsClearSearch_Click"/>
                </Grid>

                <Border Grid.Row="2" CornerRadius="8" Background="{StaticResource Card}"
                        BorderBrush="{StaticResource Line}" BorderThickness="0.8">
                    <ListView x:Name="VpsList" Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource Text}" AlternationCount="2"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="40">
                                    <GridViewColumn.Header>
                                        <CheckBox x:Name="VpsSelectAll" Style="{StaticResource ChkCell}"
                                                  IsThreeState="True" ToolTip="Selecionar todos"
                                                  Click="VpsSelectAll_Click"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource ChkCell}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="NOME" Width="296">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource Text}"
                                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Path}" Foreground="{StaticResource Muted}"
                                                           FontSize="10" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>

                <TextBlock Grid.Row="3" x:Name="VpsCountLabel" Text="0 viewpoint(s)"
                           Foreground="{StaticResource MutedLight}" FontSize="11"
                           FontFamily="Cascadia Mono, Consolas" Margin="2,8,0,0"/>
            </Grid>
        </Grid>

        <!-- ===================== Barra de ações ===================== -->
        <Border Grid.Row="2" Padding="20,14,20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Dica à esquerda -->
                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedLight}" FontSize="11"
                           Text="Marque itens e clique em 'Remover selecionados', ou use 'Limpar tudo'."/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="RefreshButton" Content="Atualizar"
                            Style="{StaticResource BtnSecondary}" Margin="0,0,8,0"
                            Click="RefreshButton_Click"/>
                    <Button x:Name="RemoveSelectedButton" Content="Remover selecionados"
                            Style="{StaticResource BtnCta}" Margin="0,0,8,0"
                            Click="RemoveSelectedButton_Click"/>
                    <Button x:Name="ClearAllButton" Content="Limpar tudo"
                            Style="{StaticResource BtnDanger}"
                            Click="ClearAllButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== Footer ===================== -->
        <Border Grid.Row="3" Background="{StaticResource Chrome}" Padding="20,12"
                BorderThickness="0,0.8,0,0" BorderBrush="{StaticResource Line}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{StaticResource Primary}"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1" x:Name="StatusLabel" Text="Pronto"
                               Foreground="{StaticResource MutedLight}" FontSize="12"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="2" x:Name="ProgressLabel" Text=""
                               Foreground="{StaticResource Primary}" FontSize="12"
                               FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock Grid.Column="3" x:Name="VersionText" Text=""
                               Foreground="{StaticResource MutedLight}" FontSize="11" Opacity="0.85"
                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                </Grid>
                <ProgressBar Grid.Row="1" x:Name="OperationProgress"
                             Style="{StaticResource ProgressDark}"
                             Height="6" Margin="0,10,0,2"
                             Minimum="0" Maximum="100" Value="0" Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Window>
