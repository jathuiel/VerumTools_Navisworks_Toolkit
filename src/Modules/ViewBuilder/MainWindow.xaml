<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="NavisworksToolkit.Modules.ViewBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Views" Height="760" Width="820"
        MinHeight="560" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        Background="#E5E7EB"
        FontFamily="Segoe UI, San Francisco PRO, Helvetica Neue"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal">

    <!--
        Tema claro corporativo (alinhado ao DesignSystem.xaml).
        Superfícies: Bg #E5E7EB · Chrome #E0E2E6 · Card #F3F4F6.
        Texto escuro (#1F2937 / #4B5563) sobre superfícies claras; acento azul #2563EB.
        Os recursos abaixo são locais a esta janela (mantidos por estabilidade),
        espelhando os tokens canônicos do DesignSystem.
        Contraste de texto >= 4.5:1 (WCAG AA) nas combinações principais.
    -->
    <Window.Resources>

        <!-- ===================== Paleta (tema claro) ===================== -->
        <SolidColorBrush x:Key="Bg"         Color="#E5E7EB"/>  <!-- janela                 -->
        <SolidColorBrush x:Key="Chrome"     Color="#E0E2E6"/>  <!-- header / footer        -->
        <SolidColorBrush x:Key="Card"       Color="#F3F4F6"/>  <!-- fundo da lista (card)  -->
        <SolidColorBrush x:Key="HeaderBg"   Color="#D6D9DE"/>  <!-- topo da grade          -->
        <SolidColorBrush x:Key="Line"       Color="#C5C9D0"/>  <!-- bordas / divisores     -->
        <SolidColorBrush x:Key="RowLine"    Color="#C5C9D0" Opacity="0.6"/> <!-- linhas grade -->
        <SolidColorBrush x:Key="SearchBg"   Color="#F8F9FA"/>  <!-- campo busca            -->

        <SolidColorBrush x:Key="Text"       Color="#1F2937"/>  <!-- texto principal         -->
        <SolidColorBrush x:Key="Muted"      Color="#4B5563"/>  <!-- texto secundário        -->
        <SolidColorBrush x:Key="TextLight"  Color="#1F2937"/>  <!-- texto sobre chrome claro -->
        <SolidColorBrush x:Key="MutedLight" Color="#4B5563"/>  <!-- secundário sobre chrome  -->
        <SolidColorBrush x:Key="Primary"    Color="#2563EB"/>  <!-- acento / CTA (azul)      -->

        <!-- Secundário (neutro): Import / Generate / Reset -->
        <SolidColorBrush x:Key="Slate"       Color="#E5E7EB"/>
        <SolidColorBrush x:Key="SlateHover"  Color="#D1D5DB"/>
        <SolidColorBrush x:Key="SlatePress"  Color="#C5C9D0"/>
        <SolidColorBrush x:Key="SlateBorder" Color="#C5C9D0"/>

        <!-- CTA (azul institucional): Create Viewpoint -->
        <SolidColorBrush x:Key="Cta"         Color="#2563EB"/>
        <SolidColorBrush x:Key="CtaHover"    Color="#1D4ED8"/>
        <SolidColorBrush x:Key="CtaPress"    Color="#1E40AF"/>

        <!-- Hover / seleção da lista (azul suave sobre fundo claro) -->
        <SolidColorBrush x:Key="RowHover"    Color="#DCEAFE"/>
        <SolidColorBrush x:Key="RowSelect"   Color="#BFDBFE"/>

        <!-- Texto sobre superfícies de acento (botão primário / erro) -->
        <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFF"/>

        <!-- ============ Botão base (template arredondado) ============ -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="BorderThickness" Value="0"/>  <!-- botões sem borda -->
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secundário (slate) -->
        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource Slate}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SlateBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <!-- hover: inverte (cinza -> cream) para feedback claro sem 6ª cor -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SlateHover}"/>
                    <Setter Property="Foreground" Value="{StaticResource Text}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource SlatePress}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CTA (azul institucional). Texto branco => contraste forte sobre o azul. -->
        <Style x:Key="BtnCta" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource Cta}"/>
            <Setter Property="Foreground" Value="{StaticResource TextOnAccent}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CtaHover}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextOnAccent}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource CtaPress}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextOnAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============ Campo de busca (input com lupa + placeholder, dark) ============ -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Primary}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource Primary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" CornerRadius="6"
                                Background="{StaticResource SearchBg}"
                                BorderBrush="{StaticResource Line}" BorderThickness="1.5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Lupa (círculo + cabo) desenhada com stroke -->
                                <Path Grid.Column="0" Margin="11,0,8,0" VerticalAlignment="Center"
                                      Stroke="{StaticResource MutedLight}" StrokeThickness="1.6"
                                      Data="M7,7 m-5,0 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0 M11,11 L15,15"/>
                                <!-- Placeholder: visível só quando o texto está vazio -->
                                <TextBlock x:Name="ph" Grid.Column="1" Text="Buscar selection set..."
                                           Foreground="{StaticResource MutedLight}"
                                           VerticalAlignment="Center" Margin="2,0,34,0"
                                           Visibility="Collapsed" IsHitTestVisible="False"/>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1"
                                              Margin="0,0,34,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="ph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão "limpar busca" (✕ discreto, sobreposto à direita do campo) -->
        <Style x:Key="ClearBtn" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="Limpar busca"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="cb" CornerRadius="11" Background="Transparent">
                            <Path x:Name="xp" HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M6,6 L14,14 M14,6 L6,14"
                                  Stroke="{StaticResource MutedLight}" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="cb" Property="Background" Value="{StaticResource SearchBg}"/>
                                <Setter TargetName="xp" Property="Stroke" Value="{StaticResource TextLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ Cabeçalho da GridView (sobre o card claro) ============ -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{StaticResource HeaderBg}"
                                BorderBrush="{StaticResource RowLine}"
                                BorderThickness="0,0,1,1"
                                Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ Item da lista (row claro + hover/seleção) ============ -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource RowLine}"
                                BorderThickness="0,0,0,1"
                                Padding="2,7">
                            <GridViewRowPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource RowAlt}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource RowHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource RowSelect}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ Checkbox (seleção múltipla) ============ -->
        <Style x:Key="ChkCell" TargetType="CheckBox">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="box" Width="18" Height="18" CornerRadius="4"
                                Background="{StaticResource Card}"
                                BorderBrush="{StaticResource SlateBorder}" BorderThickness="1.5"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <!-- marcado -->
                                <Path x:Name="check" Visibility="Collapsed"
                                      Data="M4,9 L8,13 L14,5"
                                      Stroke="{StaticResource TextOnAccent}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"/>
                                <!-- indeterminado (seleção parcial no cabeçalho) -->
                                <Rectangle x:Name="dash" Visibility="Collapsed"
                                           Width="9" Height="2" RadiusX="1" RadiusY="1" Fill="{StaticResource TextOnAccent}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="{StaticResource Primary}"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="{x:Null}">
                                <Setter TargetName="box" Property="Background" Value="{StaticResource Primary}"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                <Setter TargetName="dash" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ Barra de progresso (track + preenchimento arredondados) ============ -->
        <!-- Template enxuto (determinado): a ProgressBar redimensiona PART_Indicator
             conforme Value/Maximum. HorizontalAlignment=Left faz o preenchimento crescer
             da esquerda; os cantos arredondados casam track e fill. -->
        <Style x:Key="ProgressDark" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource Primary}"/>
            <Setter Property="Background" Value="{StaticResource SearchBg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="4" Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <Grid x:Name="PART_Track" ClipToBounds="True">
                                <Border x:Name="PART_Indicator" CornerRadius="4"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ RadioButton do painel (escuro, com bolinha laranja) ============ -->
        <Style x:Key="PanelRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3,0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="outer" Width="16" Height="16" CornerRadius="8"
                                    Background="Transparent" BorderThickness="1.5"
                                    BorderBrush="{StaticResource MutedLight}" VerticalAlignment="Center">
                                <Ellipse x:Name="dot" Width="8" Height="8"
                                         Fill="{StaticResource Primary}" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="outer" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="outer" Property="BorderBrush" Value="{StaticResource Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ CheckBox do painel (escuro, com rótulo à direita) ============ -->
        <Style x:Key="PanelCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3,0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="box" Width="16" Height="16" CornerRadius="4"
                                    Background="Transparent" BorderThickness="1.5"
                                    BorderBrush="{StaticResource MutedLight}" VerticalAlignment="Center">
                                <Path x:Name="check" Visibility="Collapsed"
                                      Data="M3,8 L7,12 L13,4"
                                      Stroke="{StaticResource TextOnAccent}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="{StaticResource Primary}"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Root: Grid (3 linhas). Sem Canvas — linhas '*' precisam de um container que
         distribua espaço, o que o Canvas não faz (dá tamanho infinito aos filhos). -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===================== Header ===================== -->
        <Border Grid.Row="0" Background="{StaticResource Chrome}" Padding="20,14"
                BorderThickness="0,0,0,1" BorderBrush="{StaticResource Line}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- barra de acento -->
                    <ColumnDefinition Width="*"/>      <!-- títulos          -->
                    <ColumnDefinition Width="Auto"/>  <!-- logo (canto dir.) -->
                </Grid.ColumnDefinitions>

                <!-- Barra de acento (laranja primário) -->
                <Border Grid.Column="0" Width="4" CornerRadius="2"
                        Background="{StaticResource Primary}" Margin="0,2,14,2"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Smart Views" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextLight}"/>
                    <TextBlock Text="Crie Viewpoints a partir dos Selection Sets"
                               FontSize="12" Foreground="{StaticResource MutedLight}" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Logo (Source definido no code-behind, com fallback seguro) -->
                <Image Grid.Column="2" x:Name="PartnersLogo" Height="86" Stretch="Uniform"
                       VerticalAlignment="Center" Margin="16,0,0,0"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"/>
            </Grid>
        </Border>

        <!-- ===================== Content ===================== -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Coluna esquerda: rótulo + busca + card da lista (lista cresce com a janela) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="SELECTION SETS DISPONÍVEIS"
                           FontWeight="SemiBold" FontSize="11"
                           Foreground="{StaticResource MutedLight}" Margin="2,0,0,8"/>

                <!-- Campo de busca: TextBox (com lupa+placeholder) + botão limpar sobreposto -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <TextBox x:Name="SearchBox" Style="{StaticResource SearchBox}"
                             TextChanged="SearchBox_TextChanged"/>
                    <Button x:Name="ClearSearchButton" Style="{StaticResource ClearBtn}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,8,0" Visibility="Collapsed"
                            Click="ClearSearchButton_Click"/>
                </Grid>

                <Border Grid.Row="2" CornerRadius="8" Background="{StaticResource Card}"
                        BorderBrush="{StaticResource Line}" BorderThickness="1">
                    <ListView x:Name="SelectionSetsList"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{StaticResource Text}" AlternationCount="2"
                              SelectionChanged="SelectionSetsList_SelectionChanged"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="40">
                                    <GridViewColumn.Header>
                                        <CheckBox x:Name="SelectAllCheckBox" Style="{StaticResource ChkCell}"
                                                  IsThreeState="True" ToolTip="Selecionar todos"
                                                  Click="SelectAllCheckBox_Click"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource ChkCell}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="NOME" Width="210">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}"
                                                       FontWeight="SemiBold" Padding="8,0,0,0"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="ITENS" Width="58">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ItemCount}" Foreground="{StaticResource Text}"
                                                       FontFamily="Cascadia Mono, Consolas"
                                                       TextAlignment="Right" Width="44"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="DESCRIÇÃO" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource Muted}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Grid>

            <!-- Painel de ações + configuração (rolável p/ caber em janelas baixas) -->
            <ScrollViewer Grid.Column="1" Margin="20,0,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <StackPanel VerticalAlignment="Top">

                <!-- ===== Configuração de geração ===== -->
                <TextBlock Text="ISOLAMENTO" FontWeight="SemiBold" FontSize="11"
                           Foreground="{StaticResource MutedLight}" Margin="0,0,0,6"/>
                <RadioButton x:Name="IsoSourceFileRadio" GroupName="Isolation"
                             Style="{StaticResource PanelRadio}" IsChecked="True"
                             Content="Até o Source File (com contexto)"
                             ToolTip="Mantém o nível: ghosting nos elementos do mesmo Source File e oculta os demais."/>
                <RadioButton x:Name="IsoSetOnlyRadio" GroupName="Isolation"
                             Style="{StaticResource PanelRadio}"
                             Content="Apenas itens do SET"
                             ToolTip="Oculta tudo que não pertence ao set — mostra somente a geometria selecionada."/>

                <TextBlock Text="CÂMERA" FontWeight="SemiBold" FontSize="11"
                           Foreground="{StaticResource MutedLight}" Margin="0,14,0,6"/>
                <RadioButton x:Name="CamOrthoRadio" GroupName="Camera"
                             Style="{StaticResource PanelRadio}" IsChecked="True"
                             Content="Ortográfica"/>
                <RadioButton x:Name="CamPerspRadio" GroupName="Camera"
                             Style="{StaticResource PanelRadio}"
                             Content="Perspectiva"/>

                <TextBlock Text="VISTAS (1 viewpoint por vista)" FontWeight="SemiBold" FontSize="11"
                           Foreground="{StaticResource MutedLight}" Margin="0,14,0,6"/>
                <CheckBox x:Name="ViewIsoCheck" Style="{StaticResource PanelCheck}"
                          IsChecked="True" Content="Isométrica"
                          Checked="ViewOption_Changed" Unchecked="ViewOption_Changed"/>
                <CheckBox x:Name="ViewTopCheck" Style="{StaticResource PanelCheck}"
                          Content="Vista superior"
                          Checked="ViewOption_Changed" Unchecked="ViewOption_Changed"/>
                <CheckBox x:Name="ViewFrontCheck" Style="{StaticResource PanelCheck}"
                          Content="Vista frontal"
                          Checked="ViewOption_Changed" Unchecked="ViewOption_Changed"/>
                <CheckBox x:Name="ViewBackCheck" Style="{StaticResource PanelCheck}"
                          Content="Vista traseira"
                          Checked="ViewOption_Changed" Unchecked="ViewOption_Changed"/>
                <CheckBox x:Name="ViewLeftCheck" Style="{StaticResource PanelCheck}"
                          Content="Vista lateral esquerda"
                          Checked="ViewOption_Changed" Unchecked="ViewOption_Changed"/>
                <CheckBox x:Name="ViewRightCheck" Style="{StaticResource PanelCheck}"
                          Content="Vista lateral direita"
                          Checked="ViewOption_Changed" Unchecked="ViewOption_Changed"/>

                <Border Height="1" Background="{StaticResource Line}" Margin="0,16,0,16"/>

                <!-- ===== Ações ===== -->
                <TextBlock Text="AÇÕES" FontWeight="SemiBold" FontSize="11"
                           Foreground="{StaticResource MutedLight}" Margin="0,0,0,12"/>

                <Button x:Name="ImportTemplateButton" Content="Importar template (.xlsx)"
                        Style="{StaticResource BtnSecondary}" Margin="0,0,0,8"
                        Click="ImportTemplateButton_Click"/>

                <Button x:Name="GenerateTemplateButton" Content="Gerar modelo (.xlsx)"
                        Style="{StaticResource BtnSecondary}" Margin="0,0,0,8"
                        Click="GenerateTemplateButton_Click"/>

                <Button x:Name="CreateViewpointButton" Content="Criar Viewpoints"
                        Style="{StaticResource BtnCta}" Margin="0,4,0,8"
                        Click="CreateViewpointButton_Click"/>

                <Button x:Name="CancelButton" Content="Cancelar"
                        Style="{StaticResource BtnSecondary}" Margin="0,0,0,8"
                        Visibility="Collapsed"
                        Click="CancelButton_Click"/>

                <Button x:Name="ResetButton" Content="Restaurar Visibilidade"
                        Style="{StaticResource BtnSecondary}" Margin="0,0,0,18"
                        Click="ResetButton_Click"/>

                <Border Height="1" Background="{StaticResource Line}" Margin="0,2,0,16"/>

                <TextBlock Text="ESTATÍSTICAS" FontWeight="SemiBold" FontSize="11"
                           Foreground="{StaticResource MutedLight}" Margin="0,0,0,10"/>
                <TextBlock x:Name="CountLabel" Text="Selection Sets: 0"
                           Foreground="{StaticResource TextLight}" FontFamily="Cascadia Mono, Consolas"
                           FontSize="12" Margin="0,0,0,6"/>
                <TextBlock x:Name="ViewpointsLabel" Text="Viewpoints: 0"
                           Foreground="{StaticResource TextLight}" FontFamily="Cascadia Mono, Consolas"
                           FontSize="12"/>
                <TextBlock x:Name="EstTimeLabel" Text="Tempo est.: —"
                           Foreground="{StaticResource Primary}" FontFamily="Cascadia Mono, Consolas"
                           FontSize="12" Margin="0,6,0,0"/>
            </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ===================== Footer ===================== -->
        <Border Grid.Row="2" Background="{StaticResource Chrome}" Padding="20,12"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource Line}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Linha de status: indicador + mensagem (esquerda), percentual (direita) -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{StaticResource Primary}"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1" x:Name="StatusLabel" Text="Pronto"
                               Foreground="{StaticResource MutedLight}" FontSize="12"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="2" x:Name="ProgressLabel" Text=""
                               Foreground="{StaticResource Primary}" FontSize="12"
                               FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock Grid.Column="3" x:Name="VersionText" Text=""
                               Foreground="{StaticResource MutedLight}" FontSize="11" Opacity="0.85"
                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                </Grid>

                <!-- Barra: largura total (responsiva), oculta quando ocioso -->
                <ProgressBar Grid.Row="1" x:Name="OperationProgress"
                             Style="{StaticResource ProgressDark}"
                             Height="6" Margin="0,10,0,2"
                             Minimum="0" Maximum="100" Value="0"
                             Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Window>
